rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: vehicles
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - capacity: number (required)
    //   - transmission: string (required, 'Manual' or 'Automatic')
    //   - fuel: string (required)
    //   - year: number (required)
    //   - images: list of strings (required)
    //   - facilities: list of strings (required)
    //   - terms: string (required)
    //   - status: string (required, 'Available', 'Rented', 'Maintenance')
    //
    // Collection: routePrices
    // Document ID: auto-generated
    // Fields:
    //   - vehicleId: string (required)
    //   - origin: string (required)
    //   - destination: string (required)
    //   - price: number (required)
    //
    // Collection: destinations
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - description: string (required)
    //   - image: string (required)
    //   - price: number (optional)
    //
    // Collection: articles
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - content: string (required)
    //   - image: string (required)
    //   - date: string (required)
    //
    // Collection: gallery
    // Document ID: auto-generated
    // Fields:
    //   - url: string (required)
    //   - caption: string (required)
    //
    // Collection: finances
    // Document ID: auto-generated
    // Fields:
    //   - date: string (required)
    //   - type: string (required, 'Income' or 'Expense')
    //   - amount: number (required)
    //   - description: string (required)
    //   - category: string (required)
    //
    // Collection: activities
    // Document ID: auto-generated
    // Fields:
    //   - vehicleId: string (required)
    //   - date: string (required)
    //   - time: string (required)
    //   - route: string (required)
    //   - type: string (required)
    //   - customerName: string (required)
    //   - description: string (required)
    //   - status: string (required, 'Scheduled', 'On Trip', 'Completed', 'Cancelled', 'Maintenance')
    //
    // Collection: settings
    // Document ID: 'global'
    // Fields:
    //   - siteName: string (required)
    //   - tagline: string (required)
    //   - description: string (required)
    //   - whatsappNumbers: list of strings (required)
    //   - googleMapsIframe: string (required)
    //   - seoKeywords: string (required)
    //
    // Collection: users
    // Document ID: user uid
    // Fields:
    //   - email: string (required)
    //   - role: string (required, 'admin')
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "aguspuryanto@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function isValidDateString(dateStr) {
      return dateStr is string && dateStr.matches("^\\d{4}-\\d{2}-\\d{2}.*$");
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidVehicle() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['name', 'capacity', 'transmission', 'fuel', 'year', 'images', 'facilities', 'terms', 'status']) &&
             hasRequiredFields(['name', 'capacity', 'transmission', 'fuel', 'year', 'images', 'facilities', 'terms', 'status']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.capacity is number && data.capacity > 0 &&
             data.transmission in ['Manual', 'Automatic'] &&
             data.fuel is string && data.fuel.size() > 0 && data.fuel.size() < 50 &&
             data.year is number && data.year > 1900 &&
             data.images is list && data.images.size() <= 10 &&
             data.facilities is list && data.facilities.size() <= 20 &&
             data.terms is string && data.terms.size() < 2000 &&
             data.status in ['Available', 'Rented', 'Maintenance'];
    }

    function isValidRoutePrice() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['vehicleId', 'origin', 'destination', 'price']) &&
             hasRequiredFields(['vehicleId', 'origin', 'destination', 'price']) &&
             data.vehicleId is string && data.vehicleId.size() > 0 &&
             data.origin is string && data.origin.size() > 0 && data.origin.size() < 100 &&
             data.destination is string && data.destination.size() > 0 && data.destination.size() < 100 &&
             data.price is number && data.price >= 0;
    }

    function isValidDestination() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['title', 'description', 'image', 'price']) &&
             hasRequiredFields(['title', 'description', 'image']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 5000 &&
             isValidUrl(data.image) &&
             (!('price' in data) || (data.price is number && data.price >= 0));
    }

    function isValidArticle() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['title', 'content', 'image', 'date']) &&
             hasRequiredFields(['title', 'content', 'image', 'date']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 20000 &&
             isValidUrl(data.image) &&
             isValidDateString(data.date);
    }

    function isValidGalleryImage() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['url', 'caption']) &&
             hasRequiredFields(['url', 'caption']) &&
             isValidUrl(data.url) &&
             data.caption is string && data.caption.size() < 500;
    }

    function isValidFinanceRecord() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['date', 'type', 'amount', 'description', 'category']) &&
             hasRequiredFields(['date', 'type', 'amount', 'description', 'category']) &&
             isValidDateString(data.date) &&
             data.type in ['Income', 'Expense'] &&
             data.amount is number && data.amount >= 0 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 1000 &&
             data.category is string && data.category.size() > 0 && data.category.size() < 100;
    }

    function isValidVehicleActivity() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['vehicleId', 'date', 'time', 'route', 'type', 'customerName', 'description', 'status']) &&
             hasRequiredFields(['vehicleId', 'date', 'time', 'route', 'type', 'customerName', 'description', 'status']) &&
             data.vehicleId is string && data.vehicleId.size() > 0 &&
             isValidDateString(data.date) &&
             data.time is string && data.time.size() > 0 && data.time.size() < 20 &&
             data.route is string && data.route.size() > 0 && data.route.size() < 200 &&
             data.type is string && data.type.size() > 0 && data.type.size() < 100 &&
             data.customerName is string && data.customerName.size() > 0 && data.customerName.size() < 100 &&
             data.description is string && data.description.size() < 2000 &&
             data.status in ['Scheduled', 'On Trip', 'Completed', 'Cancelled', 'Maintenance'];
    }

    function isValidSettings() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['siteName', 'tagline', 'description', 'whatsappNumbers', 'googleMapsIframe', 'seoKeywords']) &&
             hasRequiredFields(['siteName', 'tagline', 'description', 'whatsappNumbers', 'googleMapsIframe', 'seoKeywords']) &&
             data.siteName is string && data.siteName.size() > 0 && data.siteName.size() < 100 &&
             data.tagline is string && data.tagline.size() < 200 &&
             data.description is string && data.description.size() < 1000 &&
             data.whatsappNumbers is list && data.whatsappNumbers.size() <= 10 &&
             data.googleMapsIframe is string && data.googleMapsIframe.size() < 2000 &&
             data.seoKeywords is string && data.seoKeywords.size() < 1000;
    }

    function isValidUser() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['email', 'role']) &&
             hasRequiredFields(['email', 'role']) &&
             data.email is string && data.email.size() > 0 && data.email.size() < 200 &&
             data.role in ['admin'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /vehicles/{vehicleId} {
      allow read: if true; // Public website needs this
      allow create: if isAdmin() && isValidVehicle();
      allow update: if isAdmin() && isValidVehicle();
      allow delete: if isAdmin();
    }

    match /routePrices/{routePriceId} {
      allow read: if true; // Public website needs this
      allow create: if isAdmin() && isValidRoutePrice();
      allow update: if isAdmin() && isValidRoutePrice();
      allow delete: if isAdmin();
    }

    match /destinations/{destinationId} {
      allow read: if true; // Public website needs this
      allow create: if isAdmin() && isValidDestination();
      allow update: if isAdmin() && isValidDestination();
      allow delete: if isAdmin();
    }

    match /articles/{articleId} {
      allow read: if true; // Public website needs this
      allow create: if isAdmin() && isValidArticle();
      allow update: if isAdmin() && isValidArticle();
      allow delete: if isAdmin();
    }

    match /gallery/{imageId} {
      allow read: if true; // Public website needs this
      allow create: if isAdmin() && isValidGalleryImage();
      allow update: if isAdmin() && isValidGalleryImage();
      allow delete: if isAdmin();
    }

    match /finances/{financeId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidFinanceRecord();
      allow update: if isAdmin() && isValidFinanceRecord();
      allow delete: if isAdmin();
    }

    match /activities/{activityId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidVehicleActivity();
      allow update: if isAdmin() && isValidVehicleActivity();
      allow delete: if isAdmin();
    }

    match /settings/global {
      allow read: if true; // Public website needs this
      allow create: if isAdmin() && isValidSettings();
      allow update: if isAdmin() && isValidSettings();
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidUser();
      allow update: if isAdmin() && isValidUser();
      allow delete: if isAdmin();
    }
  }
}
